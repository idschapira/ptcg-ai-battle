# Processed artifacts (rebuilt from data/raw by src/ingestion/build_card_model.py)
/data/processed/*.parquet
/data/processed/energy_ab/
/data/processed/counterfactual/
/data/processed/replay_dataset.*
/data/processed/bc_dataset.*
/data/processed/bc_alakazam/
/data/processed/bc_spidops/
/data/processed/bc_grimmsnarl/
/data/processed/exit_grimmsnarl/
/data/processed/replays/
/data/processed/meta_radar/
/data/processed/portfolio/
/data/portfolio_watch.md
/data/processed/effects_to_review.csv

# Raw Kaggle replays (redownload: python -m src.ingestion.replays_download)
/data/raw/replays/
/viewer/replays/

# Our own ladder episodes (refetch: python -m src.analysis.fetch_my_episodes)
/viewer/episodes/

# Daily ELO tracking (volatile, rebuilt by scripts/track_elo.sh)
/data/elo/

# Torch checkpoint + train metrics (dev artifacts; the exported
# models/policy_value.npz used at runtime IS versioned)
/models/*.pt
/models/*.metrics.json
# BC do piloto líder (sparring/dev — só versionar se promovido a ship)
/models/bc_alakazam*
/models/bc_spidops*
/models/bc_grimmsnarl*
# ...promovido: a v2 é o piloto do Final B (par CASADO com feature_stats.npz)
!/models/bc_spidops_v2.npz

# Submission bundles (rebuilt by src/build_submission.py [--target spidops])
/submission.tar.gz
/submission_spidops.tar.gz

# Recorded dev games (regenerate: selfplay --record viewer/recordings);
# viewer/sample_game.json stays versioned as a small working example
/viewer/recordings/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
pokemon-tcg-ai-battle/
