# Processed artifacts (rebuilt from data/raw by src/ingestion/build_card_model.py)
/data/processed/*.parquet
/data/processed/replay_dataset.*
/data/processed/bc_dataset.*
/data/processed/replays/
/data/processed/effects_to_review.csv

# Raw Kaggle replays (redownload: python -m src.ingestion.replays_download)
/data/raw/replays/
/viewer/replays/

# Daily ELO tracking (volatile, rebuilt by scripts/track_elo.sh)
/data/elo/

# Torch checkpoint + train metrics (dev artifacts; the exported
# models/policy_value.npz used at runtime IS versioned)
/models/*.pt
/models/*.metrics.json

# Submission bundle (rebuilt by src/build_submission.py)
/submission.tar.gz

# Recorded dev games (regenerate: selfplay --record viewer/recordings);
# viewer/sample_game.json stays versioned as a small working example
/viewer/recordings/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
pokemon-tcg-ai-battle/
